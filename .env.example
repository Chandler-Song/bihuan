# =====================================================
# BiHuan - 环境变量模板
# 用途：复制此文件为 .env 并填写真实值
# 命令：cp .env.example .env
# =====================================================

# ===== 通用 =====
NODE_ENV=production
PORT=3001

# ===== JWT =====
# ⚠️ 生产环境必须使用随机生成的长字符串
# 生成命令：openssl rand -hex 32
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=7d

# ===== SQLite =====
# Docker 环境：/app/data/bihuan.db
# 本地环境：./data/bihuan.db
SQLITE_PATH=/app/data/bihuan.db

# ===== Redis =====
# Docker 环境：redis://redis:6379
# 本地环境：redis://127.0.0.1:6379
REDIS_URL=redis://redis:6379

# ===== 邮件 (SMTP) =====
MAIL_HOST=smtp.163.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=your-email@163.com
MAIL_PASS=your-authorization-code
MAIL_FROM="闭环 BiHuan <your-email@163.com>"

# ===== AI: 阿里云通义千问 (DashScope OpenAI 兼容模式) =====
QWEN_API_KEY=sk-your-api-key-here
QWEN_MODEL=qwen3.5-flash
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ===== 限流 =====
GLOBAL_RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=20

# ===== 日志 =====
LOG_LEVEL=info

# ===== 跨域（默认同源）=====
CORS_ORIGIN=
