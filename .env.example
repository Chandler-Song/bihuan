# ===== 通用 =====
NODE_ENV=production
PORT=3001

# ===== JWT =====
# ⚠️ 生产请改为长随机字符串（建议 openssl rand -hex 32）
JWT_SECRET=please-change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ===== SQLite =====
SQLITE_PATH=/app/data/bihuan.db

# ===== Redis =====
REDIS_URL=redis://redis:6379

# ===== 邮件 (SMTP) =====
MAIL_HOST=smtp.qq.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=
MAIL_PASS=
MAIL_FROM="闭环 BiHuan <noreply@example.com>"

# ===== AI: 阿里云通义千问 (DashScope OpenAI 兼容模式) =====
QWEN_API_KEY=
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ===== 限流（可选覆盖默认值）=====
GLOBAL_RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=20

# ===== 日志 =====
LOG_LEVEL=info

# ===== 跨域（默认同源）=====
CORS_ORIGIN=
